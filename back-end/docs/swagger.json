  "info": {
    "title": "EMCP API",
    "description": "Event Management & Coordination Platform REST API. Role is passed via the x-user-role header. User ID is passed via the x-user-id header for user-specific operations.",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@emcp.io"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "example": "john@emcp.io"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "role": {
            "type": "string",
            "example": "ORGANIZER",
            "enum": [
              "SUPER_USER",
              "ADMIN",
              "ORGANIZER",
              "ATTENDEE",
              "STAFF"
            ]
          },
          "status": {
            "type": "string",
            "example": "Active"
          },
          "orgDept": {
            "type": "string",
            "example": "CS Dept"
          }
        },
        "required": [
          "name",
          "email",
          "password",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "orgDept": {
            "type": "string"
          }
        }
      },
      "CreateVenueDto": {
        "type": "object",
        "properties": {
          "venueName": {
            "type": "string",
            "example": "Grand Auditorium"
          },
          "location": {
            "type": "string",
            "example": "Main Campus, Building 4"
          },
          "capacity": {
            "type": "number",
            "example": 500
          },
          "status": {
            "type": "string",
            "example": "Active"
          }
        },
        "required": [
          "venueName",
          "capacity"
        ]
      },
      "UpdateVenueDto": {
        "type": "object",
        "properties": {
          "venueName": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "capacity": {
            "type": "number"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CreateResourceDto": {
        "type": "object",
        "properties": {
          "resourceName": {
            "type": "string",
            "example": "Projector"
          },
          "quantity": {
            "type": "number",
            "example": 10
          }
        },
        "required": [
          "resourceName",
          "quantity"
        ]
      },
      "UpdateResourceDto": {
        "type": "object",
        "properties": {
          "resourceName": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          }
        }
      },
      "CreateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Tech Innovators Forum 2026"
          },
          "description": {
            "type": "string",
            "example": "A day of discovery and demos."
          },
          "imageUrl": {
            "type": "string",
            "example": ""
          },
          "eventDate": {
            "type": "string",
            "example": "2026-05-15"
          },
          "startTime": {
            "type": "string",
            "example": "09:00"
          },
          "endTime": {
            "type": "string",
            "example": "12:00"
          },
          "capacity": {
            "type": "number",
            "example": 250
          },
          "organizerId": {
            "type": "string",
            "example": "u3"
          },
          "venueId": {
            "type": "string",
            "example": "v1"
          }
        },
        "required": [
          "title",
          "eventDate",
          "startTime",
          "endTime",
          "capacity",
          "organizerId",
          "venueId"
        ]
      },
      "UpdateEventDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "eventDate": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "capacity": {
            "type": "number"
          },
          "organizerId": {
            "type": "string"
          },
          "venueId": {
            "type": "string"
          }
        }
      },
      "CreateRegistrationDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "u4"
          },
          "eventId": {
            "type": "string",
            "example": "e1"
          }
        },
        "required": [
          "userId",
          "eventId"
        ]
      },
      "UpdateAttendanceDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "PRESENT",
            "enum": [
              "PENDING",
              "PRESENT",
              "ABSENT"
            ]
          },
          "attendanceTime": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "CreateEventStaffDto": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "example": "e1"
          },
          "staffId": {
            "type": "string",
            "example": "u5"
          },
          "role": {
            "type": "string",
            "example": "Main Stage Setup"
          },
          "shiftStart": {
            "type": "string",
            "example": "09:00"
          },
          "shiftEnd": {
            "type": "string",
            "example": "12:00"
          },
          "status": {
            "type": "string",
            "example": "ASSIGNED"
          }
        },
        "required": [
          "eventId",
          "staffId",
          "role",
          "shiftStart",
          "shiftEnd"
        ]
      },
      "UpdateEventStaffDto": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string"
          },
          "staffId": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "shiftStart": {
            "type": "string"
          },
          "shiftEnd": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        }
      },
      "CreateEventResourceDto": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string",
            "example": "e1"
          },
          "resourceId": {
            "type": "string",
            "example": "r1"
          },
          "quantityUsed": {
            "type": "number",
            "example": 2
          }
        },
        "required": [
          "eventId",
          "resourceId",
          "quantityUsed"
        ]
      },
      "UpdateEventResourceDto": {
        "type": "object",
        "properties": {
          "eventId": {
            "type": "string"
          },
          "resourceId": {
            "type": "string"
          },
          "quantityUsed": {
            "type": "number"
          }
        }
      },
      "CreateNotificationDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "u5"
          },
          "title": {
            "type": "string",
            "example": "New task assigned!"
          },
          "message": {
            "type": "string",
            "example": "You have been added to the support team."
          },
          "type": {
            "type": "string",
            "example": "info"
          }
        },
        "required": [
          "userId",
          "title",
          "message"
        ]
      }
    }
  }
