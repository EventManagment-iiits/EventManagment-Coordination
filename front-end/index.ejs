<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="EMCP — the modern event management and coordination platform for institutions. Organize, manage, and execute college events with role-based access for organizers, staff, and attendees."
    />
    <title>EMCP | Event Management & Coordination Platform</title>
    <link rel="stylesheet" href="css/base.css" />
    <link rel="stylesheet" href="css/public.css" />
    <link rel="stylesheet" href="css/landing.css" />
    <link rel="icon" type="image/png" href="assets/favicon.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand-link" href="/">
          <img src="assets/favicon.png" alt="" class="brand-mark" />
          <span class="brand-text">EMCP</span>
        </a>
        <nav class="header-nav" aria-label="Primary">
          <a class="nav-link active" href="/">Home</a>
          <a
            class="nav-link"
            href="/attendee"
            data-auth="required"
            data-roles="ATTENDEE"
            >Browse Events</a
          >
          <a class="nav-link" href="/login" data-auth="public">Login</a>
          <a
            class="nav-link nav-link-pill"
            href="/signup-organizer"
            data-auth="public"
            >Sign up</a
          >
        </nav>
      </div>
    </header>

    <main class="container page">
        <section class="hero">
            <div class="hero-copy">
                <div class="pill">Academic & Professional Excellence</div>
                <h1>Seamless Event Management for <span class="text-primary">Institutions</span></h1>
                <p class="hero-subtitle">Coordinate, manage, and execute college events with a role-based platform for organizers, staff, and attendees.</p>
                <div class="hero-actions">
                    <a class="btn-primary" href="/login">Get Started</a>
                    <a class="btn-secondary" href="/login">View Demo</a>
                </div>
                <div class="hero-meta">Trusted by campus event teams</div>
            </div>
            <div class="hero-art" aria-hidden="true">
                <img src="assets/IIITS.png" alt="IIITS" />
            </div>
        </section>

      <section class="section">
        <div class="section-head">
          <h2>Why Choose EMCP?</h2>
          <p class="muted">
            Designed for high-stakes coordination with real-time insights.
          </p>
        </div>

        <div class="feature-grid">
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">▦</div>
            <h3>Centralized Hub</h3>
            <p class="muted">
              Manage venues, events, registrations, and staff from one
              dashboard.
            </p>
          </article>
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">▣</div>
            <h3>Real-time Analytics</h3>
            <p class="muted">
              Track registrations and attendance as events progress.
            </p>
          </article>
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">▤</div>
            <h3>Secure Networking</h3>
            <p class="muted">
              Role-based access to keep operational controls protected.
            </p>
          </article>
        </div>
      </section>

      <section class="section">
        <div class="section-head section-head-row">
          <div>
            <h2>Upcoming Events</h2>
            <p class="muted">
              Join the world’s leading academic and professional gatherings.
            </p>
          </div>
          <a class="text-link" href="/login">View All →</a>
        </div>
        <div id="landing-events" class="event-grid" aria-live="polite"></div>
        <div id="landing-events-empty" class="empty-state hidden">
          No upcoming events yet.
        </div>
      </section>

      <section class="cta-band">
        <h2>Ready to elevate your event management experience?</h2>
        <p>
          Start with a role-based portal for super users, admins, organizers,
          staff, and attendees.
        </p>
        <div class="cta-actions">
          <a class="btn-primary" href="/login">Get Started Free</a>
          <a class="btn-secondary" href="/login">Contact Coordinator</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <div class="brand-text">EMCP</div>
          <div class="muted">
            The platform for modern campus event coordination.
          </div>
        </div>
        <div class="footer-links">
          <div>
            <div class="footer-title">Platform</div>
            <a href="/login">Features</a>
            <a href="/login">Pricing</a>
            <a href="/login">Security</a>
          </div>
          <div>
            <div class="footer-title">Support</div>
            <a href="/login">Help Center</a>
            <a href="/login">API Docs</a>
            <a href="/login">Contact</a>
          </div>
          <div>
            <div class="footer-title">Company</div>
            <a href="/login">About</a>
            <a href="/login">Careers</a>
            <a href="/login">Privacy</a>
          </div>
        </div>
      </div>
      <div class="container footer-bottom muted">
        © 2026 EMCP. All rights reserved.
      </div>
    </footer>

    <div
      id="toast-region"
      class="toast-region"
      aria-live="polite"
      aria-atomic="true"
    ></div>

    <script src="js/core/constants.js"></script>
    <script src="js/data/seed.js"></script>
    <script src="js/data/repo.js"></script>
    <script src="js/core/session.js"></script>
    <script src="js/core/rbac.js"></script>
    <script src="js/core/ui.js"></script>
    <script src="js/pages/landing.js"></script>
  </body>
</html>
