<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Staff dashboard for EMCP — view assigned shifts, update task progress, and receive team notifications." />
    <title>Staff | EMCP</title>
    <link rel="stylesheet" href="css/style.css" />
    <link rel="icon" type="image/png" href="assets/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="dashboard" data-page="staff">
        <aside class="sidebar" aria-label="Sidebar">
            <div class="brand brand-sidebar"><img src="assets/favicon.png" alt="" class="brand-mark" /> EMCP <span class="muted small">Staff</span></div>
            <nav class="nav-menu" aria-label="Modules">
                <button class="nav-item active" data-module="dashboard">Dashboard</button>
                <button class="nav-item" data-module="tasks">My Tasks</button>
                <button class="nav-item" data-module="notifications">Notifications</button>
                <button class="nav-item" data-module="settings">Settings</button>
            </nav>

            <div class="user-profile">
                <div class="avatar" id="staff-avatar">ST</div>
                <div class="user-info">
                    <div class="user-name" id="current-user-name">Staff</div>
                    <button class="text-btn" id="logout-btn" type="button">Logout</button>
                </div>
            </div>
        </aside>

        <div class="sidebar-overlay" id="sidebar-overlay"></div>
        <main class="main-content" aria-label="Main">
            <header class="topbar">
                <div style="display:flex;align-items:center;gap:12px">
                    <button class="sidebar-toggle" id="sidebar-toggle" type="button" aria-label="Toggle menu">☰</button>
                    <div>
                        <h1 id="page-title">Dashboard</h1>
                        <div class="muted" id="page-subtitle">Your assigned shifts and tasks.</div>
                    </div>
                </div>
                <div class="topbar-actions">
                    <input id="global-search" type="search" placeholder="Search tasks..." class="search-bar" />
                </div>
            </header>

            <section class="content-area">
                <div class="stats-row" id="stats-row"></div>

                <div class="module" data-module="dashboard">
                    <div class="two-col">
                        <div class="card">
                            <div class="card-head">
                                <div>
                                    <h2 class="card-title">Upcoming Task Shifts</h2>
                                    <p class="muted">Events you’re assigned to support.</p>
                                </div>
                                <button class="text-link" type="button" data-nav-module="tasks">View All</button>
                            </div>
                            <div id="upcoming-tasks" class="list"></div>
                            <div class="empty-state hidden" id="upcoming-empty">No upcoming tasks.</div>
                        </div>

                        <div class="card">
                            <div class="card-head">
                                <div>
                                    <h2 class="card-title">Recent Notifications</h2>
                                    <p class="muted">Updates about your assignments.</p>
                                </div>
                            </div>
                            <div id="recent-notifications" class="list"></div>
                            <div class="empty-state hidden" id="notifications-empty">No notifications.</div>
                        </div>
                    </div>

                    <div class="help-card">
                        <div>
                            <h3>Need Help?</h3>
                            <p>Contact your coordinator directly or check your volunteer handbook.</p>
                        </div>
                        <button class="btn-secondary" type="button">View Resources</button>
                    </div>
                </div>

                <div class="module hidden" data-module="tasks">
                    <div class="card">
                        <div class="card-head">
                            <div>
                                <h2 class="card-title">My Tasks</h2>
                                <p class="muted">Update task status without page reload.</p>
                            </div>
                        </div>
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Event</th>
                                        <th>Task Role</th>
                                        <th>Shift</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="tasks-table-body"></tbody>
                            </table>
                        </div>
                        <div class="empty-state hidden" id="tasks-empty">No assignments found.</div>
                    </div>
                </div>

                <div class="module hidden" data-module="notifications">
                    <div class="card">
                        <div class="card-head">
                            <div>
                                <h2 class="card-title">Notifications</h2>
                                <p class="muted">Demo notifications list.</p>
                            </div>
                        </div>
                        <div id="notifications-list" class="list"></div>
                    </div>
                </div>

                <div class="module hidden" data-module="settings">
                    <div class="card">
                        <div class="card-head">
                            <div>
                                <h2 class="card-title">Settings</h2>
                                <p class="muted">Profile settings (demo).</p>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="muted">This is a mock prototype; settings are limited.</div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <div id="modal" class="modal hidden" role="dialog" aria-modal="true" aria-label="Modal">
        <div class="modal-content">
            <div class="modal-head">
                <h2 id="modal-title">Update Task</h2>
                <button class="icon-btn" type="button" id="modal-close" aria-label="Close">✕</button>
            </div>
            <form id="modal-form" class="form" novalidate></form>
        </div>
    </div>

    <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="true"></div>

    <script src="js/core/constants.js"></script>
    <script src="js/data/seed.js"></script>
    <script src="js/data/repo.js"></script>
    <script src="js/core/session.js"></script>
    <script src="js/core/rbac.js"></script>
    <script src="js/core/guard.js"></script>
    <script src="js/core/validators.js"></script>
    <script src="js/core/ui.js"></script>
    <script src="js/pages/staff.js"></script>
</body>
</html>
