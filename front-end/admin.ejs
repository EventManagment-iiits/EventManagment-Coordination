<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Admin dashboard for EMCP — operational control of venue and resource management."
    />
    <title>Admin | EMCP</title>
    <link rel="stylesheet" href="css/base.css" />
    <link rel="stylesheet" href="css/dashboard.css" />
    <link rel="icon" type="image/png" href="assets/favicon.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="dashboard" data-page="admin">
      <aside class="sidebar" aria-label="Sidebar">
        <div class="brand brand-sidebar">
          <img src="assets/favicon.png" alt="" class="brand-mark" /> EMCP
          <span class="muted small">Admin</span>
        </div>
        <nav class="nav-menu" aria-label="Modules">
          <button class="nav-item active" data-module="venues">Venues</button>
          <button class="nav-item" data-module="resources">Resources</button>
        </nav>

        <div class="user-profile">
          <div class="avatar" id="admin-avatar">AD</div>
          <div class="user-info">
            <div class="user-name" id="current-user-name">Admin</div>
            <button class="text-btn" id="logout-btn" type="button">
              Logout
            </button>
          </div>
        </div>
      </aside>

      <div class="sidebar-overlay" id="sidebar-overlay"></div>
      <main class="main-content" aria-label="Main">
        <header class="topbar">
          <div style="display: flex; align-items: center; gap: 12px">
            <button
              class="sidebar-toggle"
              id="sidebar-toggle"
              type="button"
              aria-label="Toggle menu"
            >
              ☰
            </button>
            <div>
              <h1 id="page-title">Venue Management</h1>
              <div class="muted" id="page-subtitle">
                Operational control of venues and resources.
              </div>
            </div>
          </div>
          <div class="topbar-actions">
            <input
              id="global-search"
              type="search"
              placeholder="Search venues or resources..."
              class="search-bar"
            />
            <button class="btn-primary" id="primary-action" type="button">
              + Add New
            </button>
          </div>
        </header>

        <section class="content-area">
          <div class="module" data-module="venues">
            <div class="card">
              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Venue</th>
                      <th>Location</th>
                      <th>Capacity</th>
                      <th>Status</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody id="venues-table-body"></tbody>
                </table>
              </div>
              <div class="empty-state hidden" id="venues-empty">
                No venues found.
              </div>
            </div>
          </div>

          <div class="module hidden" data-module="resources">
            <div class="card">
              <div class="table-wrap">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Resource</th>
                      <th>Quantity</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody id="resources-table-body"></tbody>
                </table>
              </div>
              <div class="empty-state hidden" id="resources-empty">
                No resources found.
              </div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <div
      id="modal"
      class="modal hidden"
      role="dialog"
      aria-modal="true"
      aria-label="Modal"
    >
      <div class="modal-content">
        <div class="modal-head">
          <h2 id="modal-title">Modal</h2>
          <button
            class="icon-btn"
            type="button"
            id="modal-close"
            aria-label="Close"
          >
            ✕
          </button>
        </div>
        <form id="modal-form" class="form" novalidate></form>
      </div>
    </div>

    <div
      id="toast-region"
      class="toast-region"
      aria-live="polite"
      aria-atomic="true"
    ></div>

    <script src="js/core/constants.js"></script>
    <script src="js/data/seed.js"></script>
    <script src="js/data/repo.js"></script>
    <script src="js/core/session.js"></script>
    <script src="js/core/rbac.js"></script>
    <script src="js/core/guard.js"></script>
    <script src="js/core/validators.js"></script>
    <script src="js/core/ui.js"></script>
    <script src="js/pages/admin.js"></script>
  </body>
</html>
