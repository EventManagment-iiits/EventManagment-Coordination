<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | EMCP</title>
    <link rel="stylesheet" href="css/style.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <main class="login-split" role="main">
        <section class="login-left" aria-label="Login form">
            <a class="brand-link" href="/">
                <span class="brand-mark" aria-hidden="true">▣</span>
                <span class="brand-text">EMCP</span>
            </a>

            <h1 class="login-title">Welcome Back</h1>
            <p class="subtitle">Log in to manage your university events.</p>

            <form id="login-form" class="form" novalidate>
                <div class="form-group">
                    <label for="email">University Email</label>
                    <input id="email" name="email" type="email" autocomplete="username" placeholder="student@university.edu" />
                    <span class="error-msg" data-error-for="email"></span>
                </div>

                <div class="form-group">
                    <div class="form-label-row">
                        <label for="password">Password</label>
                        <a class="text-link" href="#" id="forgot-password">Forgot Password?</a>
                    </div>
                    <div class="input-with-icon">
                        <input id="password" name="password" type="password" autocomplete="current-password" placeholder="••••••••" />
                        <button type="button" class="icon-btn" id="toggle-password" aria-label="Toggle password visibility">👁</button>
                    </div>
                    <span class="error-msg" data-error-for="password"></span>
                </div>

                <div class="form-error-summary hidden" id="login-summary" role="alert"></div>

                <button class="btn-primary w-100" type="submit">Sign In</button>

                <div class="divider"><span>OR CONTINUE WITH</span></div>
                <div class="social-row">
                    <button class="btn-ghost" type="button" id="google-btn">Google</button>
                    <button class="btn-ghost" type="button" id="microsoft-btn">Microsoft</button>
                </div>

                <div class="muted small center mt-16">
                    New here?
                    <a class="text-link" href="/signup-organizer">Organizer</a>
                    ·
                    <a class="text-link" href="/signup-attendee">Attendee</a>
                    ·
                    <a class="text-link" href="/signup-staff">Volunteer</a>
                </div>

                <div class="demo-credentials">
                    <div class="demo-title">Demo accounts</div>
                    <div class="demo-list">
                        <div><strong>Super User</strong>: super@emcp.io / password123</div>
                        <div><strong>Admin</strong>: admin@emcp.io / password123</div>
                        <div><strong>Organizer</strong>: organizer@emcp.io / password123</div>
                        <div><strong>Attendee</strong>: attendee@emcp.io / password123</div>
                        <div><strong>Staff</strong>: staff@emcp.io / password123</div>
                    </div>
                </div>
            </form>
        </section>

        <aside class="login-right" aria-label="Marketing panel">
            <div class="marketing-card">
                <div class="marketing-badge" aria-hidden="true">▣</div>
                <h2>Elevate Your University Experience.</h2>
                <p class="muted-on-dark">Join thousands of students and faculty members coordinating world-class campus events.</p>

                <div class="marketing-widget">
                    <div class="widget-title">Next Event</div>
                    <div class="widget-sub">Annual Tech Symposium 2026</div>
                    <div class="widget-meta">+450 attending</div>
                </div>

                <blockquote class="quote">“EMCP has transformed how we manage departmental guest lectures. It’s seamless and modern.”</blockquote>
                <div class="quote-by">— Dr. Sarah Jenkins, Head of Student Affairs</div>
            </div>
        </aside>
    </main>

    <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="true"></div>

    <script src="js/core/constants.js"></script>
    <script src="js/data/seed.js"></script>
    <script src="js/data/repo.js"></script>
    <script src="js/core/session.js"></script>
    <script src="js/core/rbac.js"></script>
    <script src="js/core/validators.js"></script>
    <script src="js/core/ui.js"></script>
    <script src="js/pages/login.js"></script>
</body>
</html>
