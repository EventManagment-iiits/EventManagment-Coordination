<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Create a volunteer account on EMCP to join the campus event support team and receive task assignments." />
    <title>Create Volunteer Account | EMCP</title>
    <link rel="stylesheet" href="css/style.css" />
    <link rel="icon" type="image/png" href="assets/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <a class="brand-link" href="/">
                <img src="assets/favicon.png" alt="" class="brand-mark" />
                <span class="brand-text">EMCP</span>
            </a>
            <div class="muted small">Already have an account? <a class="text-link" href="/login">Login</a></div>
        </div>
    </header>

    <main class="container page">
        <section class="signup-split">
            <div class="signup-left">
                <h1>Create Volunteer Account</h1>
                <p class="subtitle">Join the volunteer pool and support campus events.</p>

                <form id="signup-form" class="form" novalidate>
                    <div class="form-group">
                        <label for="fullName">Full Name</label>
                        <input id="fullName" name="fullName" type="text" placeholder="Sam Volunteer" />
                        <span class="error-msg" data-error-for="fullName"></span>
                    </div>

                    <div class="form-group">
                        <label for="email">Institutional Email</label>
                        <input id="email" name="email" type="email" placeholder="name@university.edu" />
                        <span class="error-msg" data-error-for="email"></span>
                    </div>

                    <div class="form-group">
                        <label for="orgDept">Team / Department</label>
                        <input id="orgDept" name="orgDept" type="text" placeholder="Event Operations" />
                        <span class="error-msg" data-error-for="orgDept"></span>
                    </div>

                    <div class="form-group">
                        <label for="password">Password</label>
                        <input id="password" name="password" type="password" placeholder="••••••••" />
                        <span class="error-msg" data-error-for="password"></span>
                    </div>

                    <div class="form-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <input id="confirmPassword" name="confirmPassword" type="password" placeholder="••••••••" />
                        <span class="error-msg" data-error-for="confirmPassword"></span>
                    </div>

                    <div class="form-group">
                        <label class="checkbox">
                            <input id="agree" name="agree" type="checkbox" />
                            <span>I agree to the <a class="text-link" href="#">Terms of Service</a> and <a class="text-link" href="#">Privacy Policy</a></span>
                        </label>
                        <span class="error-msg" data-error-for="agree"></span>
                    </div>

                    <div class="form-error-summary hidden" id="signup-summary" role="alert"></div>

                    <button class="btn-primary w-100" type="submit">Create Volunteer Account →</button>

                    <div class="muted small center mt-16">
                        Need a different role?
                        <a class="text-link" href="/signup-organizer">Organizer</a>
                        ·
                        <a class="text-link" href="/signup-attendee">Attendee</a>
                    </div>
                </form>
            </div>

            <aside class="signup-right" aria-label="Product teaser">
                <div class="promo-card">
                    <div class="promo-media" aria-hidden="true"></div>
                    <h2>Support the <span class="underline">event crew</span></h2>
                    <p class="muted-on-dark">Get assigned to shifts, receive task updates, and collaborate with organizers.</p>
                    <ul class="promo-list">
                        <li><strong>Clear Schedules</strong><span>Know your assignments ahead of time.</span></li>
                        <li><strong>Team Alerts</strong><span>Receive notifications as plans change.</span></li>
                    </ul>
                </div>
            </aside>
        </section>
    </main>

    <div id="toast-region" class="toast-region" aria-live="polite" aria-atomic="true"></div>

    <script src="js/core/constants.js"></script>
    <script src="js/data/seed.js"></script>
    <script src="js/data/repo.js"></script>
    <script src="js/core/session.js"></script>
    <script src="js/core/validators.js"></script>
    <script src="js/core/ui.js"></script>
    <script src="js/pages/signup-staff.js"></script>
</body>
</html>
